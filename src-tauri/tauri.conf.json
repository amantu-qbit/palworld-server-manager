{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Palworld Server Manager",
  "version": "0.7.0",
  "identifier": "com.palworldservermanager.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Palworld Server Manager",
        "width": 1280,
        "height": 820,
        "minWidth": 1040,
        "minHeight": 720,
        "resizable": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Palworld dedicated server control panel",
    "longDescription": "A modern desktop control panel for managing a Palworld dedicated server via its REST API."
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/amantu-qbit/palworld-server-manager/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlBRkYxNzZGRUQyMEJGNjAKUldSZ3Z5RHRieGYvbWs1WjBRR3RpWEdOWDgrNHU1bjloSEEvZEpHMmdwVzVub2N3K3FaZHhMbW8K"
    }
  }
}
